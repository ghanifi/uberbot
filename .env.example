# Node Environment
NODE_ENV=development

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=uber_prices
DB_USER=postgres
DB_PASSWORD=postgres

# API
API_PORT=3001
API_HOST=localhost

# Uber Accounts (JSON array)
UBER_ACCOUNTS=[{"email":"bot-1@gmail.com","password":"pass1"},{"email":"bot-2@gmail.com","password":"pass2"}]

# Logging
LOG_LEVEL=info
LOG_FILE=logs/scraper.log

# Features
ENABLE_SCRAPER=true
ENABLE_API=true
